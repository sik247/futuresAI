// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  password         String?
  name             String
  nickname         String            @default("")
  phoneNumber      String            @default("")
  imageUrl         String            @default("/images/profile.png")
  role             Role              @default(USER)
  credits          Float             @default(0)
  createdAt        DateTime          @default(now()) @db.Timestamptz()
  updatedAt        DateTime          @updatedAt @db.Timestamptz()
  exchangeAccounts ExchangeAccount[]
  followers        User[]            @relation("UserFollows")
  followings       User[]            @relation("UserFollows")
  posts            Post[]
  comments         Comment[]
  postLikes        PostLike[]
  commentLikes     CommentLike[]
  chartIdeas       ChartIdea[]
  withdrawals      Withdrawal[]
  chartAnalyses    ChartAnalysis[]
  accounts         Account[]
  subscriptions    Subscription[]
  analysisUsages   AnalysisUsage[]
  portfolios       Portfolio[]
  chatMessages     ChatMessage[]
  chatEnabled      Boolean           @default(false)
  isPremium        Boolean           @default(false)
  blogArticles     BlogArticle[]
  payments         Payment[]
  // Trading profile — user tendencies, risk appetite used as agentic memory/context
  tradingProfile   Json?             @db.JsonB
  // Contact linking for invite/post program
  telegramId       String?           @unique
  telegramUsername String?
  realEmail        String?
  inviteNumber     Int?              @unique
  isFounding100    Boolean           @default(false)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Post {
  id        String     @id @default(cuid())
  title     String
  content   String
  imageUrl  String
  isLong    Boolean    @default(false)
  createdAt DateTime   @default(now()) @db.Timestamptz()
  updatedAt DateTime   @updatedAt @db.Timestamptz()
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  comments  Comment[]
  likes     PostLike[]
  hashTags  HashTag[]
}

model Comment {
  id        String        @id @default(cuid())
  content   String
  createdAt DateTime      @default(now()) @db.Timestamptz()
  updatedAt DateTime      @updatedAt @db.Timestamptz()
  Children  Comment[]     @relation("Comment_Children")
  parent    Comment?      @relation("Comment_Children", fields: [parentId], references: [id])
  parentId  String?
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  postId    String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     CommentLike[]
}

model PostLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model CommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model HashTag {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
  posts     Post[]
}

model Verification {
  id        String   @id @default(cuid())
  email     String
  code      String
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

enum Role {
  USER
  ADMIN
}

enum BannerType {
  EVENT
  INTRODUCE
}

model Banner {
  id          String     @id @default(cuid())
  title       String
  description String
  imageUrl    String
  active      Boolean
  type        BannerType @default(EVENT)
  createdAt   DateTime   @default(now()) @db.Timestamptz()
  updatedAt   DateTime   @updatedAt @db.Timestamptz()
}

model Exchange {
  id               String            @id @default(cuid())
  name             String
  imageUrl         String
  titleImageUrl    String
  paybackRatio     Float
  discountRatio    Float
  limitFee         Float
  marketFee        Float
  type             String
  tag              String
  averageIncome    Int
  link             String            @default("")
  exchangeAccounts ExchangeAccount[]
  createdAt        DateTime          @default(now()) @db.Timestamptz()
  updatedAt        DateTime          @updatedAt @db.Timestamptz()
}

enum ExchangeAccountStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model ExchangeAccount {
  id              String                @id @default(cuid())
  uid             String                @unique
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  status          ExchangeAccountStatus @default(ACTIVE)
  exchangeId      String
  exchange        Exchange              @relation(fields: [exchangeId], references: [id])
  createdAt       DateTime              @default(now()) @db.Timestamptz()
  updatedAt       DateTime              @updatedAt @db.Timestamptz()
  totalCommission Float                 @default(0)
  screenshotUrl   String?
  trades          Trade[]
  withdrawal      Withdrawal[]
}

enum TradeStatus {
  PENDING
  SUCCESS
  FAILED
}

model Trade {
  id              String          @id @default(cuid())
  accountId       String
  exchangeAccount ExchangeAccount @relation(fields: [accountId], references: [id])
  amount          Float
  payback         Float
  withdrawId      String?
  withdraw        Withdrawal?     @relation(fields: [withdrawId], references: [id])
  status          TradeStatus     @default(PENDING)
  apiCreatedAt    DateTime        @default(now()) @db.Timestamptz()
  createdAt       DateTime        @default(now()) @db.Timestamptz()
  updatedAt       DateTime        @updatedAt @db.Timestamptz()

  @@unique([accountId, apiCreatedAt, amount], name: "unique_trade")
}

enum WithdrawalStatus {
  PENDING
  SUCCESS
  FAILED
}

model Withdrawal {
  id               String            @id @default(cuid())
  exchangeAccounts ExchangeAccount[]
  amount           Float
  trades           Trade[]
  status           WithdrawalStatus  @default(PENDING)
  network          String            @default("TRC20")
  address          String            @default("")
  userId           String?
  user             User?             @relation(fields: [userId], references: [id])
  paidAt           DateTime?         @db.Timestamptz()
  adminNote        String?
  createdAt        DateTime          @default(now()) @db.Timestamptz()
  updatedAt        DateTime          @updatedAt @db.Timestamptz()
}

model PaybackCalculation {
  id           String   @id @default(cuid())
  exchangeName String
  tradeType    String
  volume       Float
  leverage     Int      @default(1)
  makerPct     Int      @default(30)
  monthlyFees  Float
  payback      Float
  yearlySavings Float
  createdAt    DateTime @default(now()) @db.Timestamptz()
}

model News {
  id        String   @id @default(cuid())
  linkUrl   String
  title     String
  content   String
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

model Event {
  id        String   @id @default(cuid())
  linkUrl   String
  imageUrl  String
  title     String
  content   String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()
}

enum TradeDirection {
  LONG
  SHORT
}

model ChartIdea {
  id          String         @id @default(cuid())
  imageUrl    String
  pair        String
  direction   TradeDirection
  entryPrice  Float
  stopLoss    Float
  takeProfit  Float
  description String
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  createdAt   DateTime       @default(now()) @db.Timestamptz()
  updatedAt   DateTime       @updatedAt @db.Timestamptz()
}

enum AnalysisStatus {
  PENDING
  APPROVED
  CHARGED
  REFUNDED
}

model ChartAnalysis {
  id              String         @id @default(cuid())
  imageUrl        String
  pair            String?
  cost            Float          @default(50.0)
  status          AnalysisStatus @default(PENDING)
  // AI analysis results (stored as JSON)
  summary         String
  trend           String
  patterns        String         @db.Text
  supportLevels   String         @db.Text
  resistanceLevels String        @db.Text
  indicators      String         @db.Text
  tradeSetup      String         @db.Text
  analysisData    String?        @db.Text
  newsContext     String?        @db.Text
  priceContext    String?        @db.Text
  riskScore       Int            @default(0)
  confidence      Int            @default(0)
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  chargedAt       DateTime?      @db.Timestamptz()
  createdAt       DateTime       @default(now()) @db.Timestamptz()
  updatedAt       DateTime       @updatedAt @db.Timestamptz()
}

model ManagedContent {
  id             String   @id @default(cuid())
  type           String   // 'tweet' | 'youtube' | 'news' | 'short'
  sourceUrl      String   @unique
  title          String
  titleKo        String   @default("")
  description    String   @db.Text
  descriptionKo  String   @default("") @db.Text
  thumbnailUrl   String?
  sourceName     String
  sourceCategory String
  publishedAt    DateTime
  fetchedAt      DateTime @default(now())
  status         String   @default("pending") // 'pending' | 'translated' | 'published' | 'archived'
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([publishedAt])
  @@index([type, status])
}

model ContentBotLog {
  id        String   @id @default(cuid())
  action    String   // 'aggregate' | 'translate' | 'publish' | 'error'
  details   String   @db.Text
  itemCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id])
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @db.Timestamptz()
  currentPeriodEnd   DateTime           @db.Timestamptz()
  createdAt          DateTime           @default(now()) @db.Timestamptz()

  @@index([userId, status])
}

model AnalysisUsage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  periodStart DateTime @db.Timestamptz()
  usageCount  Int      @default(0)

  @@unique([userId, periodStart])
}

model Portfolio {
  id        String              @id @default(cuid())
  name      String              @default("My Portfolio")
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings  Holding[]
  snapshots PortfolioSnapshot[]
  createdAt DateTime            @default(now()) @db.Timestamptz()
  updatedAt DateTime            @updatedAt @db.Timestamptz()

  @@index([userId])
}

model Holding {
  id          String    @id @default(cuid())
  coinId      String
  symbol      String
  name        String
  quantity    Float
  avgBuyPrice Float
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @db.Timestamptz()

  @@unique([portfolioId, coinId])
  @@index([portfolioId])
}

model PortfolioSnapshot {
  id          String   @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  totalValue  Float
  totalCost   Float
  snapshotAt  DateTime @default(now()) @db.Timestamptz()

  @@index([portfolioId, snapshotAt])
}

model BlogArticle {
  id          String   @id @default(cuid())
  title       String
  titleKo     String   @default("")
  content     String   @db.Text
  contentKo   String   @default("") @db.Text
  excerpt     String   @default("")
  excerptKo   String   @default("")
  imageUrl    String   @default("")
  category    String   @default("general") // general, guide, research, news
  tags        String[] @default([])
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  publishedAt DateTime? @db.Timestamptz()
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  @@index([published, publishedAt])
  @@index([category])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  persona   String
  ticker    String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([sessionId])
  @@index([userId])
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  amount     Float         @default(99)
  txid       String        @unique
  network    String        @default("TRC20")
  status     PaymentStatus @default(PENDING)
  verifiedAt DateTime?     @db.Timestamptz()
  adminNote  String?
  createdAt  DateTime      @default(now()) @db.Timestamptz()
  updatedAt  DateTime      @updatedAt @db.Timestamptz()

  @@index([userId])
  @@index([status])
}
