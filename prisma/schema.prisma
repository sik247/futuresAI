generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AnalysisUsage {
  id          String   @id
  userId      String
  periodStart DateTime @db.Timestamptz(6)
  usageCount  Int      @default(0)
  User        User     @relation(fields: [userId], references: [id])

  @@unique([userId, periodStart])
}

model Banner {
  id          String     @id
  title       String
  description String
  imageUrl    String
  active      Boolean
  type        BannerType @default(EVENT)
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @db.Timestamptz(6)
}

model ChartAnalysis {
  id               String         @id
  imageUrl         String
  pair             String?
  cost             Float          @default(50.0)
  status           AnalysisStatus @default(PENDING)
  summary          String
  trend            String
  patterns         String
  supportLevels    String
  resistanceLevels String
  indicators       String
  tradeSetup       String
  analysisData     String?
  riskScore        Int            @default(0)
  confidence       Int            @default(0)
  userId           String
  chargedAt        DateTime?      @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @db.Timestamptz(6)
  newsContext      String?
  priceContext     String?
  User             User           @relation(fields: [userId], references: [id])
}

model ChartIdea {
  id          String         @id
  imageUrl    String
  pair        String
  direction   TradeDirection
  entryPrice  Float
  stopLoss    Float
  takeProfit  Float
  description String
  userId      String
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @db.Timestamptz(6)
  User        User           @relation(fields: [userId], references: [id])
}

model Comment {
  id            String        @id
  content       String
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime      @db.Timestamptz(6)
  userId        String
  postId        String
  parentId      String?
  Comment       Comment?      @relation("CommentToComment", fields: [parentId], references: [id])
  other_Comment Comment[]     @relation("CommentToComment")
  Post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  User          User          @relation(fields: [userId], references: [id])
  CommentLike   CommentLike[]
}

model CommentLike {
  id        String   @id
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  userId    String
  commentId String
  Comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id])
}

model ContentBotLog {
  id        String   @id
  action    String
  details   String
  itemCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

model Event {
  id        String   @id
  imageUrl  String
  title     String
  content   String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  linkUrl   String
}

model Exchange {
  id              String            @id
  name            String
  imageUrl        String
  paybackRatio    Float
  discountRatio   Float
  limitFee        Float
  marketFee       Float
  type            String
  tag             String
  averageIncome   Int
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @db.Timestamptz(6)
  link            String            @default("")
  titleImageUrl   String
  ExchangeAccount ExchangeAccount[]
}

model ExchangeAccount {
  id              String                @id
  uid             String                @unique
  userId          String
  exchangeId      String
  createdAt       DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime              @db.Timestamptz(6)
  status          ExchangeAccountStatus @default(ACTIVE)
  totalCommission Float                 @default(0)
  screenshotUrl   String?
  Exchange        Exchange              @relation(fields: [exchangeId], references: [id])
  User            User                  @relation(fields: [userId], references: [id])
  Trade           Trade[]
  Withdrawal      Withdrawal[]
}

model HashTag {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  Post      Post[]
}

model Holding {
  id          String    @id
  coinId      String
  symbol      String
  name        String
  quantity    Float
  avgBuyPrice Float
  portfolioId String
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @db.Timestamptz(6)
  Portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, coinId])
  @@index([portfolioId])
}

model ManagedContent {
  id             String   @id
  type           String
  sourceUrl      String   @unique
  title          String
  titleKo        String   @default("")
  description    String
  descriptionKo  String   @default("")
  thumbnailUrl   String?
  sourceName     String
  sourceCategory String
  publishedAt    DateTime
  fetchedAt      DateTime @default(now())
  status         String   @default("pending")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime

  @@index([publishedAt])
  @@index([status])
  @@index([type])
  @@index([type, status])
}

model News {
  id        String   @id
  content   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  linkUrl   String
  title     String
}

model PaybackCalculation {
  id            String   @id
  exchangeName  String
  tradeType     String
  volume        Float
  leverage      Int      @default(1)
  makerPct      Int      @default(30)
  monthlyFees   Float
  payback       Float
  yearlySavings Float
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
}

model Portfolio {
  id                String              @id
  name              String              @default("My Portfolio")
  userId            String
  createdAt         DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime            @db.Timestamptz(6)
  Holding           Holding[]
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  PortfolioSnapshot PortfolioSnapshot[]

  @@index([userId])
}

model PortfolioSnapshot {
  id          String    @id
  portfolioId String
  totalValue  Float
  totalCost   Float
  snapshotAt  DateTime  @default(now()) @db.Timestamptz(6)
  Portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, snapshotAt])
}

model Post {
  id        String     @id
  title     String
  content   String
  imageUrl  String
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @db.Timestamptz(6)
  userId    String
  isLong    Boolean    @default(false)
  Comment   Comment[]
  User      User       @relation(fields: [userId], references: [id])
  PostLike  PostLike[]
  HashTag   HashTag[]
}

model PostLike {
  id        String   @id
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  userId    String
  postId    String
  Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id])
}

model Subscription {
  id                 String             @id
  userId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @db.Timestamptz(6)
  currentPeriodEnd   DateTime           @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @db.Timestamptz(6)
  User               User               @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Trade {
  id              String          @id
  accountId       String
  amount          Float
  payback         Float
  withdrawId      String?
  status          TradeStatus     @default(PENDING)
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @db.Timestamptz(6)
  apiCreatedAt    DateTime        @default(now()) @db.Timestamptz(6)
  ExchangeAccount ExchangeAccount @relation(fields: [accountId], references: [id])
  Withdrawal      Withdrawal?     @relation(fields: [withdrawId], references: [id])

  @@unique([accountId, apiCreatedAt, amount])
}

model User {
  id              String            @id
  email           String            @unique
  password        String?
  name            String
  phoneNumber     String            @default("")
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @db.Timestamptz(6)
  imageUrl        String            @default("/images/profile.png")
  nickname        String            @default("")
  credits         Float             @default(0)
  role            Role              @default(USER)
  Account         Account[]
  AnalysisUsage   AnalysisUsage[]
  ChartAnalysis   ChartAnalysis[]
  ChartIdea       ChartIdea[]
  Comment         Comment[]
  CommentLike     CommentLike[]
  ExchangeAccount ExchangeAccount[]
  Portfolio       Portfolio[]
  Post            Post[]
  PostLike        PostLike[]
  Subscription    Subscription[]
  Withdrawal      Withdrawal[]
  User_A          User[]            @relation("UserFollows")
  User_B          User[]            @relation("UserFollows")
}

model Verification {
  id        String   @id
  email     String
  code      String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
}

model Withdrawal {
  id              String            @id
  amount          Float
  status          WithdrawalStatus  @default(PENDING)
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @db.Timestamptz(6)
  address         String            @default("")
  network         String            @default("TRC20")
  adminNote       String?
  paidAt          DateTime?         @db.Timestamptz(6)
  userId          String?
  Trade           Trade[]
  User            User?             @relation(fields: [userId], references: [id])
  ExchangeAccount ExchangeAccount[]
}

enum AnalysisStatus {
  PENDING
  APPROVED
  CHARGED
  REFUNDED
}

enum BannerType {
  EVENT
  INTRODUCE
}

enum ExchangeAccountStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  SUCCESS
  FAILED
}
